# Copy to .env and/or .env.local at the **repo root** (same folder as package.json).
# The API server loads both via dotenv (see server/loadEnv.js). `.env.local` overrides `.env`.

OPENAI_API_KEY=your_openai_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
PORT=3001
LOG_LEVEL=info
# Optional: override the default file-backed JSON log path.
# Default behavior writes to logs/designmind-YYYY-MM-DD.ndjson.
DESIGNMIND_LOG_FILE=logs/designmind-local.ndjson

# --- Static UI + API on another host (e.g. Vercel + Fly/Railway) ---
# Vite embeds this at build time. No trailing slash.
# VITE_API_BASE_URL=https://your-api.example.com
# Express: browser origin allowed to call the API (match your Vercel URL).
# CORS_ORIGIN=https://your-app.vercel.app
